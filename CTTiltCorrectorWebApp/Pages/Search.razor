    // Test stub for UI.
    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_patientId)) return;
        _errorMessage = null;
        _results = null;
        _searching = true;

        await Task.Delay(500);
        _results = new List<DicomSeriesResult>
        {
            new("asd123", "Smith^John", "19620314", "1.2.840.10008.1", "1.2.840.10008.1.1", "HEAD ROUTINE", "CT", "20240315", 300),
            new("asd123", "Smith^John", "19620314", "1.2.840.10008.1", "1.2.840.10008.1.2", "CHEST CT", "CT", "20240315", 200),
        };
        _patientName = "Smith^John";
        _patientDOB = "19620314";
        _searching = false;
    }

    private async Task SubmitJobAsync(DicomSeriesResult series)
    {
        _submitting = true;
        try
        {
            var user = HttpContextAccessor.HttpContext?.User?.Identity?.Name ?? "Unknown";

            // Create a progress sink that streams messages to the Monitor page
            // via a shared singleton (MonitorState injected from DI).
            var progress = new Progress<string>(_ => { }); // wired in Monitor page

            var job = new CorrectionJob(
                series.PatientId,
                series.StudyInstanceUid,
                series.SeriesInstanceUid,
                user);

            await JobQueue.TryEnqueueAsync(job, progress);

            Snackbar.Add(
                $"Job queued for series {TruncateUid(series.SeriesInstanceUid)}. " +
                "View progress on the Monitor page.",
                Severity.Success);

            Nav.NavigateTo("/monitor");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to queue job: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string FormatDate(string raw)
    {
        if (raw.Length == 8 &&
            DateTime.TryParseExact(raw, "yyyyMMdd",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var dt))
            return dt.ToString("dd MMM yyyy");
        return raw;
    }

    private static string Initials(string dicomName)
    {
        if (string.IsNullOrWhiteSpace(dicomName))
            return "?";

        // Take only the alphabetic component group (before any '=')
        var alphabetic = dicomName.Split('=')[0];

        // Split into components: Family^Given^Middle^Prefix^Suffix
        var parts = alphabetic.Split('^');

        var family = parts.ElementAtOrDefault(0)?.Trim();
        var given = parts.ElementAtOrDefault(1)?.Trim();

        return (string.IsNullOrEmpty(family), string.IsNullOrEmpty(given)) switch
        {
            (false, false) => $"{given[0]}{family[0]}",   // JS  (John Smith)
            (false, true) => $"{family[0]}",              // S   (family only)
            (true, false) => $"{given[0]}",               // J   (given only)
            _ => "?"                           // nothing usable
        };
    }

    private static string FormatPatientName(string dicomName)
    {
        if (string.IsNullOrWhiteSpace(dicomName))
            return "Unknown";

        var alphabetic = dicomName.Split('=')[0];
        var parts = alphabetic.Split('^');

        var family = parts.ElementAtOrDefault(0)?.Trim();
        var given = parts.ElementAtOrDefault(1)?.Trim();

        return (string.IsNullOrEmpty(family), string.IsNullOrEmpty(given)) switch
        {
            (false, false) => $"{given} {family}",
            (false, true) => family,
            (true, false) => given,
            _ => "Unknown"
        };
    }

    private static string TruncateUid(string uid)
        => uid.Length > 20 ? "…" + uid[^20..] : uid;
}
