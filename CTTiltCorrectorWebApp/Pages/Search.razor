@page "/search"
@inject DicomQueryService DicomQuery
@inject CorrectionJobQueue JobQueue
@inject IHttpContextAccessor HttpContextAccessor
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Search — CT Tilt Corrector</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
    Patient Series Search
</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Style="width: fit-content">
            <MudTextField @bind-Value="_patientId"
                          Label="Patient ID (MRN)"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Immediate="true"
                          OnKeyDown="@OnKeyDown"
                          Style="width: 300px" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="SearchAsync"
                       Disabled="_searching">
                @if (_searching)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Search ARIA
            </MudButton>
        </MudStack>

        @if (_results is not null)
        {
            <MudPaper Elevation="0" Class="pa-3 d-flex align-center"
                      Style="border: 0.5px solid var(--mud-palette-lines-default); border-radius: 12px; gap: 12px;">
                <MudAvatar Color="Color.Info" Size="Size.Medium" Style="font-size:17px; font-weight:700">
                    @Initials(_patientName)
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.body1" Style="font-weight:500; line-height:1.2">
                        @FormatPatientName(_patientName)
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        DOB: @FormatDate(_patientDOB)
                    </MudText>
                </div>
            </MudPaper>
        }

    </MudStack>
</MudPaper>

@if (_errorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
}

@if (_results is not null)
{
    <MudText Typo="Typo.subtitle1" Class="mb-2">
        Found <strong>@_results.Count</strong> CT series
    </MudText>

    <MudTable Items="_results"
              Hover="true"
              Striped="true"
              Dense="true"
              Elevation="2"
              Loading="_searching">
        <HeaderContent>
            <MudTh>Series Date</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Modality</MudTh>
            <MudTh Style="text-align:center">Images</MudTh>
            <MudTh>Series UID</MudTh>
            <MudTh Style="text-align:center">Action</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@FormatDate(context.SeriesDate)</MudTd>
            <MudTd>@context.SeriesDescription</MudTd>
            <MudTd><MudChip T="string" Color="Color.Info" Size="Size.Small">@context.Modality</MudChip></MudTd>
            <MudTd Style="text-align:center">@context.NumberOfImages</MudTd>
            <MudTd Style="font-family:monospace; font-size:0.75rem">@TruncateUid(context.SeriesInstanceUid)</MudTd>
            <MudTd Style="text-align:center">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Straighten"
                           OnClick="() => SubmitJobAsync(context)"
                           Disabled="_submitting">
                    Correct Tilt
                </MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No CT series found for this patient ID.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    private string _patientId = string.Empty;
    private string _patientName = string.Empty;
    private string _patientDOB = string.Empty;
    private bool _searching;
    private bool _submitting;
    private string? _errorMessage;
    private List<DicomSeriesResult>? _results;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

