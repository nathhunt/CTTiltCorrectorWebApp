@using CTTiltCorrector
@namespace CTTiltCorrector.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CT Tilt Corrector</title>
    <base href="~/" />

    <!-- MudBlazor CSS -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />

    <!-- App CSS (optional, add wwwroot/app.css if needed) -->
    <link href="app.css" rel="stylesheet" />
    <link href="CTTiltCorrector.styles.css" rel="stylesheet" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <!-- MudBlazor JS -->
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>

    <!-- Blazor Server JS -->
    <script src="_framework/blazor.server.js"></script>

    <!-- Utility: auto-scroll terminal to bottom -->
    <script>
        window.scrollToBottom = (elementId) => {
            const el = document.getElementById(elementId);
            if (el) el.scrollIntoView({ behavior: 'smooth' });
        };
    </script>
</body>
</html>
