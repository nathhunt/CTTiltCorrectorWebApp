<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <MudAlert Severity="Severity.Error" Class="ma-4">
                        <MudText Typo="Typo.h6">Access Denied</MudText>
                        <MudText>
                            Your account is not authorised to use CT Tilt Corrector.
                            Contact your administrator to be added to the required AD group.
                        </MudText>
                    </MudAlert>
                </NotAuthorized>
                <Authorizing>
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not Found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudAlert Severity="Severity.Warning" Class="ma-4">
                    Page not found.
                </MudAlert>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
